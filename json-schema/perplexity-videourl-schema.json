{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/VideoURL",
  "title": "VideoURL",
  "properties": {
    "url": {
      "type": "string",
      "title": "Url"
    },
    "frame_interval": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "integer"
        }
      ],
      "title": "Frame Interval",
      "default": 25
    }
  },
  "type": "object",
  "required": [
    "url"
  ]
}